rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    match /tailors/{tailorId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == tailorId && isImage();
    }

    match /tailors/{tailorId}/samples/{fileName} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == tailorId && isImage();
    }

    match /bookings/{customerId}/references/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == customerId && isImage();
    }
  }
}

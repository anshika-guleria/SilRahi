rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Tailor profile photos
    match /tailors/{tailorId}/photo/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == tailorId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Tailor work samples
    match /tailors/{tailorId}/samples/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == tailorId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Booking cloth/design reference images
    match /bookings/{bookingId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
